                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentRedBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="MAX DD" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsMaxDD9}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentAmberBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="PROFIT FACTOR" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsPF9}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="5,0,0,0"><Grid><Border Background="{StaticResource AccentBlueBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="TRADES" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsTrades9}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                    </UniformGrid>
                                    <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="10" Height="160" Margin="0,0,0,8">
                                        <controls:EquityCurveCanvas EquityCurve="{Binding Backtest.EquityCurve9}" Margin="4"/>
                                    </Border>
