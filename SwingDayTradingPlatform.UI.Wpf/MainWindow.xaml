            <!-- ============ ALERTS TAB ============ -->
            <TabItem Header="Alerts">
                <Border Background="#1E1E2E" CornerRadius="0,0,10,10">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Config + Controls Card -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Mode toggle + core settings -->
                                <WrapPanel Margin="0,0,0,10">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="MODE" Style="{StaticResource ParamLabel}"/>
                                        <Border Background="#111827" CornerRadius="8" Padding="3" Height="34">
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="ModeReplay" GroupName="AlertMode"
                                                             IsChecked="{Binding Alerts.IsReplayMode, Mode=OneWay}"
                                                             Checked="OnAlertModeReplay" Cursor="Hand">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="Bd" CornerRadius="6" Padding="14,4" Background="Transparent" SnapsToDevicePixels="True">
                                                                <TextBlock x:Name="Txt" Text="Replay" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#3B82F6"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsChecked" Value="False"/>
                                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#94A3B8"/>
                                                                </MultiTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                                <RadioButton x:Name="ModeRealtime" GroupName="AlertMode"
                                                             Checked="OnAlertModeRealtime" Cursor="Hand">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Border x:Name="Bd" CornerRadius="6" Padding="14,4" Background="Transparent" SnapsToDevicePixels="True">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse x:Name="Dot" Width="6" Height="6" Fill="#64748B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="Txt" Text="Realtime" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#10B981"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                                                    <Setter TargetName="Dot" Property="Fill" Value="White"/>
                                                                </Trigger>
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsChecked" Value="False"/>
                                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#94A3B8"/>
                                                                </MultiTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="SYMBOL" Style="{StaticResource ParamLabel}"/>
                                        <TextBox Width="80" Height="32" Text="{Binding Alerts.Symbol, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="EXCHANGE" Style="{StaticResource ParamLabel}"/>
                                        <TextBox Width="70" Height="32" Text="{Binding Alerts.Exchange, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="LOOKBACK" Style="{StaticResource ParamLabel}"/>
                                        <TextBox Width="60" Height="32" Text="{Binding Alerts.Lookback, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
