                                        <RowDefinition Height="Auto" MinHeight="400"/>
                                    </Grid.RowDefinitions>
                                    <UniformGrid Columns="6" Margin="0,0,0,8">
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,5,0"><Grid><Border Background="{StaticResource AccentGreenBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="NET P&amp;L" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsNetPnL12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentBlueBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="WIN RATE" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsWinRate12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentBlueBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="SHARPE" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsSharpe12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentRedBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="MAX DD" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsMaxDD12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="3,0"><Grid><Border Background="{StaticResource AccentAmberBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="PROFIT FACTOR" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsPF12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
                                        <Border Style="{StaticResource StatCard}" Margin="5,0,0,0"><Grid><Border Background="{StaticResource AccentBlueBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="2" Margin="-14,-12,0,-12"/><StackPanel Margin="2,0,0,0"><TextBlock Text="TRADES" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8"/><TextBlock Text="{Binding Backtest.StatsTrades12}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/></StackPanel></Grid></Border>
