<Window x:Class="SwingDayTradingPlatform.UI.Wpf.AlertsDayDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SwingDayTradingPlatform.UI.Wpf.Controls"
        Title="Alerts Day Chart"
        Width="1440"
        Height="900"
        MinWidth="1000"
        MinHeight="700"
        Background="#0F172A"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="12" Padding="24,16" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                    <GradientStop Color="#1B3044" Offset="0"/>
                    <GradientStop Color="#2B6CB0" Offset="0.7"/>
                    <GradientStop Color="#7C9DC4" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ALERTS DAY CHART" FontSize="12.5" FontWeight="Bold" Foreground="#94B8D8"
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontFamily="Segoe UI" Opacity="0.85"/>
                        <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtAlertCount" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TxtDateDisplay" FontSize="22" FontWeight="Bold" Foreground="White"
                               Margin="0,8,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Close" Width="100" Height="40"
                        Background="#1AFFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                        BorderThickness="1" FontWeight="SemiBold" Cursor="Hand"
                        VerticalAlignment="Top" Click="BtnClose_Click"/>
            </Grid>
        </Border>

        <!-- Legend strip -->
        <Border Grid.Row="1" Background="#1A1A2A" CornerRadius="6" Padding="14,6" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Background="#E17055" CornerRadius="3" Padding="8,2" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="PEAK (MAX)" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                </Border>
                <Border Background="#00B894" CornerRadius="3" Padding="8,2" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="VALLEY (MIN)" FontSize="10" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                </Border>
                <Border Width="1" Background="#334155" Margin="6,2,14,2"/>
                <Border Background="#38BDF8" CornerRadius="3" Width="20" Height="3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="EMA" FontSize="10" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center" FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Chart canvas -->
        <Border Grid.Row="2" Background="#1E1E2E" CornerRadius="12" ClipToBounds="True"
                BorderBrush="#2A3A50" BorderThickness="1">
            <controls:ChartCanvas x:Name="DayChart"/>
        </Border>
    </Grid>
</Window>
