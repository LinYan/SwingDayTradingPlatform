<Window x:Class="SwingDayTradingPlatform.UI.Wpf.DayDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SwingDayTradingPlatform.UI.Wpf.Controls"
        Title="Day Detail"
        Width="1440"
        Height="1440"
        MinWidth="1000"
        MinHeight="800"
        Background="#0F172A"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PnLCell" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        <Style x:Key="DirCell" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#253347"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#1A2332"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="400"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="340" MinHeight="220"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="12" Padding="24,16" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                    <GradientStop Color="#1B3044" Offset="0"/>
                    <GradientStop Color="#2B6CB0" Offset="0.7"/>
                    <GradientStop Color="#7C9DC4" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DAY DETAIL" FontSize="11" FontWeight="Bold" Foreground="#94B8D8"
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontFamily="Segoe UI" Opacity="0.85"/>
                        <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStrategyName" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" FontFamily="Consolas"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TxtDateDisplay" FontSize="22" FontWeight="Bold" Foreground="White"
                               Margin="0,8,0,0" FontFamily="Consolas"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Close" Width="88" Height="36"
                        Background="#1AFFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                        BorderThickness="1" FontWeight="SemiBold" Cursor="Hand"
                        VerticalAlignment="Top" Click="BtnClose_Click"/>
            </Grid>
        </Border>

        <!-- Stats cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,10">
            <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="0,0,8,0" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="TOTAL P&amp;L" FontSize="9.5" FontWeight="SemiBold" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtTotalPnl" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="4,0" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="TRADES" FontSize="9.5" FontWeight="SemiBold" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtTradeCount" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="4,0" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="WIN RATE" FontSize="9.5" FontWeight="SemiBold" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtWinRate" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="4,0" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="AVG TRADE" FontSize="9.5" FontWeight="SemiBold" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtAvgTrade" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
            <Border Background="#1E293B" CornerRadius="10" Padding="16,12" Margin="8,0,0,0" BorderBrush="#334155" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="MAX DRAWDOWN" FontSize="9.5" FontWeight="SemiBold" Foreground="#64748B" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TxtMaxDD" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" Foreground="#E17055" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Chart canvas -->
        <Border Grid.Row="2" Background="#1E1E2E" CornerRadius="12" ClipToBounds="True" Margin="0,0,0,8"
                BorderBrush="#2A3A50" BorderThickness="1">
            <controls:ChartCanvas x:Name="DayChart"
                Bars="{Binding DayBars}"
                FastEmaValues="{Binding Ema20Values}"
                VwapValues="{Binding VwapValues}"
                TradeMarkers="{Binding TradeMarkers}"/>
        </Border>

        <!-- Trades header -->
        <Border Grid.Row="3" CornerRadius="10,10,0,0" Padding="18,10" BorderBrush="#334155" BorderThickness="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E293B" Offset="0"/>
                    <GradientStop Color="#253347" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="TRADE LOG" FontSize="12" FontWeight="Bold" Foreground="#94A3B8"
                               VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,14,0"/>
                    <TextBlock x:Name="TxtTradeCountGrid" FontSize="11" Foreground="#64748B"
                               VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#0F9D7A" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                        <TextBlock Text="ENTRY" FontSize="8.5" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#38BDF8"/>
                        </Border.Background>
                        <TextBlock Text="EXIT" FontSize="8.5" FontWeight="Bold" Foreground="#0F172A" FontFamily="Segoe UI"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Trades grid -->
        <Border Grid.Row="4" CornerRadius="0,0,12,12" ClipToBounds="True" BorderBrush="#334155" BorderThickness="1,0,1,1">
            <Border.Background>
                <SolidColorBrush Color="#1E293B"/>
            </Border.Background>
            <DataGrid x:Name="TradesGrid" AutoGenerateColumns="False" IsReadOnly="True" AlternationCount="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="14,10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Direction}" Value="Long">
                                        <Setter Property="Foreground" Value="#00B894"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Direction}" Value="Short">
                                        <Setter Property="Foreground" Value="#E17055"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Entry Time" Binding="{Binding EntryTime, StringFormat='{}{0:HH:mm}'}" Width="72" FontFamily="Consolas">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#0F9D7A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="14,10"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Exit Time" Binding="{Binding ExitTime, StringFormat='{}{0:HH:mm}'}" Width="72" FontFamily="Consolas">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#38BDF8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="14,10"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Entry $" Binding="{Binding EntryPrice, StringFormat=F2}" Width="90" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Exit $" Binding="{Binding ExitPrice, StringFormat=F2}" Width="90" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="P&amp;L Pts" Binding="{Binding PnLPoints, StringFormat=F2}" Width="85" CellStyle="{StaticResource PnLCell}"/>
                    <DataGridTextColumn Header="P&amp;L $" Binding="{Binding PnLDollars, StringFormat=N2}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="14,10"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Hold" Binding="{Binding HoldTimeFormatted}" Width="70"/>
                    <DataGridTextColumn Header="MAE" Binding="{Binding MAE, StringFormat=F2}" Width="70" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="MFE" Binding="{Binding MFE, StringFormat=F2}" Width="70" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Entry Reason" Binding="{Binding EntryReason}" Width="*"/>
                    <DataGridTextColumn Header="Exit Reason" Binding="{Binding ExitReason}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
